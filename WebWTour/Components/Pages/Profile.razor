@page "/profile"
@using WebWTour.Database
@using WebWTour.Models
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject TourContext ef
@rendermode InteractiveServer

<PageTitle>Личный кабинет | World Tour</PageTitle>

<div class="profile-container">
    <!-- Фоновое изображение -->
    <img class="background-image" src="image 12.png" alt="Background" />
    <div class="overlay"></div>

    <Header />

    <!-- Контент -->
    <div class="profile-content">
        <div class="profile-container-custom">
            <!-- Информация о пользователе -->
            <div class="profile-card glass-card">
                <div class="profile-header">
                    <div class="profile-avatar">
                        <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                    </div>
                    <div class="profile-info">
                        <h1 class="profile-name">@AuthService.CurrentUser?.Name @AuthService.CurrentUser?.Surname</h1>
                        <p class="profile-email">@AuthService.CurrentUser?.Email</p>
                        <p class="profile-date">Зарегистрирован: @AuthService.CurrentUser?.RegistrationDate.ToString("dd.MM.yyyy")</p>
                    </div>
                </div>
            </div>

            <!-- Корзина -->
            <div class="cart-section glass-card">
                <h2 class="section-title">🛒 Моя корзина</h2>
                
                @if (AuthService.CartItems.Count == 0)
                {
                    <div class="empty-cart">
                        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                            <circle cx="9" cy="21" r="1"/>
                            <circle cx="20" cy="21" r="1"/>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                        </svg>
                        <p>Ваша корзина пуста</p>
                        <a href="/" class="btn-browse">Посмотреть туры</a>
                    </div>
                }
                else
                {
                    <div class="cart-items">
                        @foreach (var item in AuthService.CartItems)
                        {
                            <div class="cart-item">
                                <img class="cart-item-image" src="@item.Tour.ImageLink" alt="@item.Tour.Tittle" />
                                <div class="cart-item-details">
                                    <h3 class="cart-item-title">@item.Tour.Tittle</h3>
                                    <p class="cart-item-place">📍 @item.Tour.Place</p>
                                    <p class="cart-item-price">@item.Tour.Price.ToString("N0") ₽</p>
                                </div>
                                <div class="cart-item-actions">
                                    <div class="quantity-control">
                                        <button class="quantity-btn" @onclick="() => UpdateQuantity(item.OrderId, item.Quantity - 1)">-</button>
                                        <span class="quantity-value">@item.Quantity</span>
                                        <button class="quantity-btn" @onclick="() => UpdateQuantity(item.OrderId, item.Quantity + 1)">+</button>
                                    </div>
                                    <button class="remove-btn" @onclick="() => RemoveItem(item.OrderId)">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <line x1="18" y1="6" x2="6" y2="18"/>
                                            <line x1="6" y1="6" x2="18" y2="18"/>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                    
                    <div class="cart-summary">
                        <div class="summary-row">
                            <span>Итого:</span>
                            <span class="summary-total">@AuthService.CartTotal.ToString("N0") ₽</span>
                        </div>
                        <button class="btn-checkout" @onclick="Checkout">
                            Оформить заказ
                        </button>
                        <button class="btn-clear" @onclick="ClearCart">
                            Очистить корзину
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private async Task UpdateQuantity(int orderId, int quantity)
    {
        await AuthService.UpdateQuantity(orderId, quantity);
        StateHasChanged();
    }

    private async Task RemoveItem(int orderId)
    {
        await AuthService.RemoveFromCart(orderId);
        StateHasChanged();
    }

    private async Task ClearCart()
    {
        await AuthService.ClearCart();
        StateHasChanged();
    }

    private async Task Checkout()
    {
        await AuthService.CompleteOrder();
        StateHasChanged();
    }

    private async Task Logout()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/", true);
    }

    private void GoToHome()
    {
        Navigation.NavigateTo("/", true);
    }
}
@page "/"
@using Microsoft.EntityFrameworkCore
@implements IDisposable
@using WebWTour.Database
@inject TourContext ef
@using WebWTour.Models
@inject AuthService AuthService
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>World Tour | Путешествия мечты</PageTitle>

<div class="home-container">
    <!-- Фоновое изображение -->
    <img class="background-image" src="image 12.png" alt="Background" />

    <!-- Полупрозрачный оверлей для улучшения читаемости -->
    <div class="overlay"></div>

    <!-- Шапка -->
    <Header />

    <!-- Центральный блок с фильтром - по центру экрана -->
    <div class="main-content">
        <div class="search-section">
            <div class="search-card glass-card">
                <div class="search-form">
                    <div class="search-field">
                        <label class="field-label">Куда</label>
                        <div class="autocomplete-container">
                            <input type="text"
                                   class="field-input"
                                   placeholder="Страна, город, курорт"
                                   @bind="_searchPlace"
                                   @oninput="OnPlaceInput" />
                            @if (_suggestions.Count > 0 && !string.IsNullOrEmpty(_searchPlace))
                            {
                            <div class="autocomplete-dropdown">
                                @foreach (var suggestion in _suggestions.Take(5))
                                {
                                <div class="autocomplete-item" @onclick="() => SelectPlace(suggestion)">
                                    @suggestion
                                </div>
                                }
                            </div>
                            }
                        </div>
                    </div>

                    <div class="search-field">
                        <label class="field-label">Когда</label>
                        <input type="text"
                               class="field-input"
                               placeholder="Выберите дату"
                               @bind="_searchDate"
                               @onclick="ShowDatePicker"
                               readonly />
                        @if (_showDatePicker)
                        {
                        <div class="date-picker-dropdown">
                            <div class="date-picker-header">
                                <button class="date-nav" @onclick="PreviousMonth">◀</button>
                                <span class="date-month">@_currentMonth.ToString("MMMM yyyy")</span>
                                <button class="date-nav" @onclick="NextMonth">▶</button>
                            </div>
                            <div class="date-picker-calendar">
                                @for (int i = 0; i < 7; i++)
                                {
                                <div class="date-weekday">@_weekdays[i]</div>
                                }
                                @for (int i = 0; i < _firstDayOffset; i++)
                                {
                                <div class="date-empty"></div>
                                }
                                @for (int day = 1; day <= DateTime.DaysInMonth(_currentMonth.Year, _currentMonth.Month); day++)
                                {
                                var currentDate = new DateTime(_currentMonth.Year, _currentMonth.Month, day);
                                var isSelected = _selectedDate.HasValue && _selectedDate.Value.Date == currentDate.Date;
                                var isToday = DateTime.Today.Date == currentDate.Date;
                                <div class="date-day @(isSelected ? "selected" : "") @(isToday ? "today" : "")"
                                     @onclick="() => SelectDate(currentDate)">
                                    @day
                                </div>
                                }
                            </div>
                        </div>
                        }
                    </div>

                    <div class="search-field">
                        <label class="field-label">Кто едет</label>
                        <div class="guests-input">
                            <input type="text"
                                   class="field-input"
                                   placeholder="2 взрослых"
                                   value="@_guestsText"
                                   readonly
                                   @onclick="ShowGuestsPicker" />
                            @if (_showGuestsPicker)
                            {
                            <div class="guests-picker-dropdown">
                                <div class="guests-picker-item">
                                    <span>Взрослые</span>
                                    <div class="guests-counter">
                                        <button class="counter-btn" @onclick="() => UpdateAdults(-1)">-</button>
                                        <span>@_adults</span>
                                        <button class="counter-btn" @onclick="() => UpdateAdults(1)">+</button>
                                    </div>
                                </div>
                                <div class="guests-picker-item">
                                    <span>Дети</span>
                                    <div class="guests-counter">
                                        <button class="counter-btn" @onclick="() => UpdateChildren(-1)">-</button>
                                        <span>@_children</span>
                                        <button class="counter-btn" @onclick="() => UpdateChildren(1)">+</button>
                                    </div>
                                </div>
                                <button class="guests-apply" @onclick="ApplyGuests">Применить</button>
                            </div>
                            }
                        </div>
                    </div>

                    <button class="search-button" @onclick="SearchTours">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/>
                            <path d="M21 21l-4.35-4.35"/>
                        </svg>
                        Найти
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Каталог туров -->
    <div class="catalog-section">
        <div class="catalog-container">
            <div class="catalog-header">
                <h2 class="catalog-title">Популярные направления</h2>
                <p class="catalog-subtitle">Выберите страну для незабываемого путешествия</p>
                @if (_isFiltered)
                {
                <button class="reset-filters" @onclick="ResetFilters">Сбросить фильтры</button>
                }
            </div>

            <div class="countries-grid">
                @if (_filteredTours.Count == 0)
                {
                <div class="no-results">
                    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                        <circle cx="11" cy="11" r="8"/>
                        <path d="M21 21l-4.35-4.35"/>
                    </svg>
                    <p>По вашему запросу ничего не найдено</p>
                    <button class="btn-browse" @onclick="ResetFilters">Посмотреть все туры</button>
                </div>
                }
                else
                {
                @foreach (var item in _filteredTours)
                {
                <div class="country-card glass-card-tour">
                    <div class="card-image">
                        <img src="@item.ImageLink" alt="@item.Tittle" />
                        <div class="card-badge">@item.BookType</div>
                    </div>
                    <div class="card-content">
                        <h3 class="card-title">@item.Tittle</h3>
                        <p class="card-place">📍 @item.Place</p>
                        <p class="card-description">@item.Description</p>
                        <div class="card-info">
                            <span class="card-season">🌤️ @item.Season</span>
                            <span class="card-price">@item.Price.ToString("N0") ₽</span>
                        </div>
                        <div class="card-dates">
                            <span>📅 @item.OpenDate.ToString("dd.MM.yyyy") - @item.CloseDate.ToString("dd.MM.yyyy")</span>
                        </div>
                        <button class="card-button" @onclick="() => GoToTour(item.Id)">Подробнее →</button>
                    </div>
                </div>
                }
                }
            </div>

            @if (!_isFiltered && _filteredTours.Count < _allTours.Count && _filteredTours.Count > 0)
            {
            <div class="show-more-container">
                <button class="show-more-button" @onclick="LoadMoreTours">
                    Показать ещё
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M6 9l6 6 6-6"/>
                    </svg>
                </button>
            </div>
            }
        </div>
    </div>
</div>

@code {
private List<Models.Tour> _allTours = new();
private List<Models.Tour> _filteredTours = new();
private List<Models.Tour> _displayedTours = new();
private int _currentDisplayCount = 20;
private const int ToursPerPage = 20;
private Random _random = new Random();

// Фильтры
private string _searchPlace = "";
private string _searchDate = "";
private DateTime? _selectedDate;
private int _adults = 2;
private int _children = 0;
private string _guestsText = "2 взрослых";
private bool _isFiltered = false;

// Автодополнение для стран
private List<string> _allPlaces = new();
private List<string> _suggestions = new();

// Датапикер
private bool _showDatePicker = false;
private DateTime _currentMonth = DateTime.Today;
private string[] _weekdays = { "Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс" };
private int _firstDayOffset;

// Пикер гостей
private bool _showGuestsPicker = false;

protected override async Task OnInitializedAsync()
{
await AuthService.InitializeAsync();
LoadTours();
AuthService.OnAuthStateChanged += StateHasChanged;
AuthService.OnCartChanged += StateHasChanged;
}

private void LoadTours()
{
_allTours = ef.Tours.OrderBy(t => t.Id).ToList();
_allPlaces = _allTours.Select(t => t.Place).Distinct().ToList();
ShuffleTours();
_filteredTours = _allTours.ToList();
_displayedTours = _filteredTours.Take(_currentDisplayCount).ToList();
UpdateMonthOffset();
}

private void ShuffleTours()
{
for (int i = _allTours.Count - 1; i > 0; i--)
{
int j = _random.Next(i + 1);
var temp = _allTours[i];
_allTours[i] = _allTours[j];
_allTours[j] = temp;
}
}

private void OnPlaceInput(ChangeEventArgs e)
{
_searchPlace = e.Value?.ToString() ?? "";
if (!string.IsNullOrEmpty(_searchPlace))
{
_suggestions = _allPlaces
.Where(p => p.Contains(_searchPlace, StringComparison.OrdinalIgnoreCase))
.ToList();
}
else
{
_suggestions.Clear();
}
StateHasChanged();
}

private void SelectPlace(string place)
{
_searchPlace = place;
_suggestions.Clear();
StateHasChanged();
}

private void ShowDatePicker()
{
_showDatePicker = !_showDatePicker;
_showGuestsPicker = false;
StateHasChanged();
}

private void PreviousMonth()
{
_currentMonth = _currentMonth.AddMonths(-1);
UpdateMonthOffset();
StateHasChanged();
}

private void NextMonth()
{
_currentMonth = _currentMonth.AddMonths(1);
UpdateMonthOffset();
StateHasChanged();
}

private void UpdateMonthOffset()
{
var firstDay = new DateTime(_currentMonth.Year, _currentMonth.Month, 1);
int firstDayOfWeek = (int)firstDay.DayOfWeek;
_firstDayOffset = firstDayOfWeek == 0 ? 6 : firstDayOfWeek - 1;
}

private void SelectDate(DateTime date)
{
_selectedDate = date;
_searchDate = date.ToString("dd.MM.yyyy");
_showDatePicker = false;
StateHasChanged();
}

private void ShowGuestsPicker()
{
_showGuestsPicker = !_showGuestsPicker;
_showDatePicker = false;
StateHasChanged();
}

private void UpdateAdults(int delta)
{
_adults = Math.Max(1, Math.Min(10, _adults + delta));
UpdateGuestsText();
StateHasChanged();
}

private void UpdateChildren(int delta)
{
_children = Math.Max(0, Math.Min(10, _children + delta));
UpdateGuestsText();
StateHasChanged();
}

private void UpdateGuestsText()
{
if (_children == 0)
{
_guestsText = $"{_adults} {GetAdultWord(_adults)}";
}
else
{
_guestsText = $"{_adults} {GetAdultWord(_adults)}, {_children} {GetChildWord(_children)}";
}
}

private string GetAdultWord(int count)
{
if (count == 1) return "взрослый";
if (count >= 2 && count <= 4) return "взрослых";
return "взрослых";
}

private string GetChildWord(int count)
{
if (count == 1) return "ребенок";
if (count >= 2 && count <= 4) return "ребенка";
return "детей";
}

private void ApplyGuests()
{
_showGuestsPicker = false;
StateHasChanged();
}

private void SearchTours()
{
var query = _allTours.AsQueryable();

// Фильтр по месту
if (!string.IsNullOrEmpty(_searchPlace))
{
query = query.Where(t => t.Place.Contains(_searchPlace, StringComparison.OrdinalIgnoreCase));
}

// Фильтр по дате
if (_selectedDate.HasValue)
{
query = query.Where(t => t.OpenDate <= _selectedDate.Value && t.CloseDate >= _selectedDate.Value);
}

_filteredTours = query.ToList();
_isFiltered = !string.IsNullOrEmpty(_searchPlace) || _selectedDate.HasValue;
_displayedTours = _filteredTours.Take(_currentDisplayCount).ToList();
StateHasChanged();
}

private void ResetFilters()
{
_searchPlace = "";
_searchDate = "";
_selectedDate = null;
_adults = 2;
_children = 0;
_guestsText = "2 взрослых";
_isFiltered = false;
_filteredTours = _allTours.ToList();
_displayedTours = _filteredTours.Take(_currentDisplayCount).ToList();
StateHasChanged();
}

private void LoadMoreTours()
{
_currentDisplayCount += ToursPerPage;
_displayedTours = _filteredTours.Take(_currentDisplayCount).ToList();
StateHasChanged();
}

private void GoToTour(int id)
{
Navigation.NavigateTo($"/tour/{id}");
}

public void Dispose()
{
AuthService.OnAuthStateChanged -= StateHasChanged;
AuthService.OnCartChanged -= StateHasChanged;
}
}